11.Examples
# fibonacci sequence calculator
# this program prints the fibonacci sequence up to a given limit

# initialize the first two numbers in the sequence
firstNumb = int(1)
secondNumb = int(1)

# variable used to store the sum of the previous two numbers
summed = int(0)

# number of iterations requested
n = int(42)

# fibonacci function
//fib.takes(limit){

    # prevent very large inputs (design choice / safety check)
    if limit > 40{
        print("choose a samller number, because I say so")

    }else{

        # loop 'limit' times and keep track of the iteration number in 'i'
        loop limit.iterval(i){

            # calculate the next fibonacci number
            summed = firstNumb + secondNumb

            # shift values forward in the sequence
            firstNumb = secondNumb;
            secondNumb = summed
            
            # print the current iteration number
            print(i, "th iteration")

            # print the fibonacci value at this step
            print(summed)
        }
    }

}

# call the fibonacci function with n as the limit
/fib(n)
